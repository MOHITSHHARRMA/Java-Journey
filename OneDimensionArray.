public class OneDimensionArray {

    public static void main(String args[]) {

        // Create an integer array capable of storing 8 elements.
        int num[] = new int[8];

        // Fill the array with random numbers from 0 to 99.
        for (int i = 0; i < num.length; i++) {

            // Math.random() generates a double between 0.0 and 1.0.
            // Multiplying by 100 gives values from 0.0 to 99.999...
            // Casting to int removes the decimal part.
            num[i] = (int) (Math.random() * 100);
        }

        // Print all elements of the array.
        for (int i = 0; i < num.length; i++) {
            System.out.print(num[i] + " ");
        }
    }
}
